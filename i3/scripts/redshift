#!/bin/bash

LANG=en_US.UTF-8
TEMPS=(3500 4500 5500 6500)
TEMP_ICONS=("🔥" "🌤️" "🌙" "❄️")

# Retorna ícone de brilho
brightness_icon() {
  if (( $(echo "$1 < 0.4" | bc -l) )); then
    echo "🔅"
  elif (( $(echo "$1 < 0.75" | bc -l) )); then
    echo "🔆"
  else
    echo "💡"
  fi
}

# Lê o brilho e temperatura atuais do redshift
read_brightness_and_temp() {
  OUT=$(redshift -p 2>/dev/null)
  BRIGHT=$(echo "$OUT" | grep "Brightness:" | awk '{print $2}')
  TEMP=$(echo "$OUT" | grep "Color temperature:" | awk '{gsub(/K/, "", $3); print $3}')
  notify-send "$BRIGHT $TEMP"
  echo "$BRIGHT $TEMP"
}

# Encontra índice da temperatura mais próxima
find_temp_index() {
  local temp=$1
  for i in "${!TEMPS[@]}"; do
    if [[ "${TEMPS[$i]}" -eq "$temp" ]]; then
      echo "$i"
      return
    fi
  done
  # Se não achar exatamente, aproxima
  closest=0
  min_diff=10000
  for i in "${!TEMPS[@]}"; do
    diff=$(( ${TEMPS[$i]} > $temp ? ${TEMPS[$i]} - $temp : $temp - ${TEMPS[$i]} ))
    if (( diff < min_diff )); then
      min_diff=$diff
      closest=$i
    fi
  done
  echo "$closest"
}

# Cicla temperatura com base no estado atual
cycle_temperature() {
  read _ TEMP <<<"$(read_brightness_and_temp)"
  CUR_IDX=$(find_temp_index "$TEMP")
  NEXT_IDX=$(( (CUR_IDX + 1) % 4 ))
  redshift -PO "${TEMPS[$NEXT_IDX]}"
}

# Ajusta brilho usando xrandr
adjust_brightness() {
  read BRIGHT _ <<<"$(read_brightness_and_temp)"
  DELTA=$1
  NEW_BRIGHT=$(echo "$BRIGHT + $DELTA" | bc -l)
  NEW_BRIGHT=$(echo "$NEW_BRIGHT" | awk '{if ($1 < 0.1) print 0.1; else if ($1 > 1.0) print 1.0; else print $1}')
  xrandr --output "$(xrandr | grep ' connected' | awk '{print $1}')" --brightness "$NEW_BRIGHT"
}

# Eventos
case "$BLOCK_BUTTON" in
  1) cycle_temperature ;;
  4) adjust_brightness 0.05 ;;
  5) adjust_brightness -0.05 ;;
esac

# Atualiza o display
read BRIGHT TEMP <<<"$(read_brightness_and_temp)"
BRIGHT_ICON=$(brightness_icon "$BRIGHT")
TEMP_IDX=$(find_temp_index "$TEMP")
TEMP_ICON="${TEMP_ICONS[$TEMP_IDX]}"

echo "$BRIGHT_ICON $TEMP_ICON"

# Atualiza o bloco se for por clique/scroll
[[ "$BLOCK_BUTTON" ]] && pkill -RTMIN+13 i3blocks
