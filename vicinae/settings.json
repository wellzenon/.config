{
   "$schema": "https://vicinae.com/schemas/config.json",
   "close_on_focus_loss": true,
   "pop_to_root_on_close": true,
   "search_files_in_root": true,
   "font": {
      "rendering": "native",
      "normal": {
         "family": "Sans Serif",
         "size": 12
      }
   },
   "theme": {
      "dark": {
         "name": "vicinae-dark"
      }
   },
   "launcher_window": {
      "opacity": 1,
      "client_side_decorations": {
         "enabled": true
      }
   },
   "favorites": [
      "power:power-off",
      "clipboard:history"
   ],
   "providers": {
      "applications": {
         "preferences": {
            "paths": [
               "/home/ton/.local/share/applications",
               "/usr/share/applications"
            ]
         },
         "entrypoints": {
            "chrome-eikjhbkpemdappjfcmdeeeamdpkgabmk-Default": {
               "enabled": false
            },
            "chrome-pjibgclleladliembfgfagdaldikeohf-Default": {
               "enabled": false
            },
            "org.mozilla.firefox.webapp-c2523256-75ee-4962-955f-d756f7619565": {
               "enabled": false
            },
            "org.mozilla.firefox.webapp-d90807f3-1de0-47ea-bbf5-b8c75094dd95": {
               "enabled": false
            },
            "org.mozilla.firefox.webapp-e86ad5d7-320c-4820-a470-d9dbf7dbdff6": {
               "enabled": false
            }
         }
      },
      "power": {
         "entrypoints": {
            "logout": {
               "preferences": {
                  "confirm": false
               }
            },
            "power-off": {
               "preferences": {
                  "confirm": false
               }
            },
            "reboot": {
               "preferences": {
                  "confirm": false
               }
            }
         }
      }
   }
}