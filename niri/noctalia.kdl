layout {

    focus-ring {
        active-color   "#b9c9d0"
        inactive-color "#121314"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#b9c9d0"
        inactive-color "#121314"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#b9c9d0"
        inactive-color "#3b494f"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#b9c9d080"
    }
}
