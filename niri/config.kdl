// blur {
//     off
//     passes 7
//     offset 1
//     noise 0.12
//     saturation 1.0
// }

// Open the Firefox picture-in-picture player as floating by default.
window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}

window-rule {
    // opacity 0.8
    draw-border-with-background true
    // geometry-corner-radius 10
    // clip-to-geometry true
    // background-effect {
    //     blur true
    //     xray true
    // }
}

window-rule {
    match is-focused=false
    opacity 0.90
    draw-border-with-background true
}

window-rule {
    match is-floating=true
    geometry-corner-radius 20
    clip-to-geometry true
    draw-border-with-background true
    // opacity 0.9
}

window-rule {
    match app-id=r#"^org\.wezfurlong\.wezterm$"#
    default-column-width {}
}

window-rule {
    match app-id=r#"^zen$"# title="^Picture-in-Picture$"
    match app-id=r#"^zen$"# title=r#"^Extension: (fx_cast) - — Zen Browser$"#
    // match app-id=r#"^yad$"#
    open-floating true
}

window-rule {
    match app-id=r#"^zen$"#
    match app-id=r#"^main-fox$"#
    default-column-width { proportion 0.5; }
    open-floating false
}

window-rule {
    match app-id=r#"^ai-fox$"#
    default-column-width { proportion 0.25; }
    open-fullscreen false
    open-maximized false
    tiled-state true
}

window-rule {
    match app-id=r#"^org.pulseaudio.pavucontrol$"#
    open-floating true
}

window-rule {
    match app-id=r#"^com.terminal.scratch$"#
    default-column-width { proportion 0.45; }
    default-window-height { proportion 0.25; }
    open-floating true
    default-floating-position x=0 y=0 relative-to="bottom"
}

// window-rule {
//     match app-id=r#"^com.mitchellh.ghostty$"#
//     match app-id=r#"^org.mozilla.firefox.webapp-c2523256-75ee-4962-955f-d756f7619565$"#
//     default-column-width { proportion 0.25; }
// }

window-rule {
    match title="spt - spotatui"
    match app-id=r#"^com.terminal.spotatui$"#
    draw-border-with-background false
}

window-rule {
    match title="notes"
    match app-id=r#"^com.terminal.notes$"#
    default-column-width { proportion 0.25; }
}

window-rule {
    match app-id=r#"^sioyek$"#
    default-column-width { proportion 0.5; }
}

window-rule {
    match app-id=r#"^com.stremio.stremio$"#
    match app-id=r#"^FFPWA-01KA54HRPPRV44B9FBEDFHMQA5$"#
    open-fullscreen true
}

window-rule {
    match app-id=r#"^rudo$"# title="^Confirm .*$"
    open-floating true
}

layer-rule {
    match namespace="^waybar$"
}

// layer-rule {
//     match namespace=r#"^vicinae$"#
//     geometry-corner-radius 10
//     clip-to-geometry true
// }

layer-rule {
    match namespace="^wallpaper$"
    match namespace="^quickshell$"
    place-within-backdrop true
}

binds {
    Mod+Shift+Slash { show-hotkey-overlay; }

    Mod+W hotkey-overlay-title="Open Firefox" { spawn-sh "nirius focus-or-spawn -a firefox prime-run firefox && niri msg action center-column"; }
    // Mod+Y hotkey-overlay-title="Open Tec Concursos" { spawn-sh "nirius focus-or-spawn -a org.mozilla.firefox.webapp-e86ad5d7-320c-4820-a470-d9dbf7dbdff6 /usr/lib/firefox-nightly/firefox -- -taskbar-ta be86ad5d7-320c-4820-a470-d9dbf7dbdff6 -new-window https://www.tecconcursos.com.br -profile /home/ton/.mozilla/firefox/x5slv4jk.default-nightly-1 -container 0 && niri msg action center-column" ; }
    // Mod+G hotkey-overlay-title="Open AI" { spawn-sh "nirius focus-or-spawn -a org.mozilla.firefox.webapp-c2523256-75ee-4962-955f-d756f7619565 /usr/lib/firefox-nightly/firefox -- -taskbar-tab 7773ab32-87a0-4c05-8d37-9d6773f408db -new-window https://gemini.google.com -profile /home/ton/.mozilla/firefox/x5slv4jk.default-nightly-1 -container 0 && niri msg action center-column" ; }

    Mod+O hotkey-overlay-title="Open Obsidian" { spawn-sh "nirius focus-or-spawn -a obsidian prime-run obsidian -- --enable-features=UseOzonePlatform --ozone-platform=wayland && niri msg action center-column"; }
    Mod+S hotkey-overlay-title="Open Sioyek" { spawn-sh "QT_QPA_PLATFORM=xcb nirius focus-or-spawn -a sioyek sioyek && niri msg action center-column"; }
    Mod+Shift+S hotkey-overlay-title="Toggle Sioyek Sepia" { spawn-sh "~/.config/niri/scripts/toggle_sioyek.sh"; }

    Mod+E hotkey-overlay-title="Open Neovim" { spawn-sh "nirius focus-or-spawn -t nvim ghostty -- +new-window -e nvim && niri msg action center-column"; }
    // Mod+N hotkey-overlay-title="Open Notes" { spawn-sh "nirius focus-or-spawn -t notes ghostty -- --env=NVIM_APPNAME=nvim-notes -e nvim ~/obsidian/TODO.md && niri msg action center-column"; }
    Mod+N hotkey-overlay-title="Open Nautilus" { spawn-sh "nautilus ~/Downloads/"; }
    Mod+A hotkey-overlay-title="Open Superfile" { spawn-sh "ghostty +new-window -e spf ~/Downloads/ && niri msg action center-column"; }
    Mod+Return hotkey-overlay-title="Open a Terminal: Ghostty" { spawn-sh "ghostty +new-window && niri msg action center-column"; }


    Mod+M hotkey-overlay-title="Open Spotatui" { spawn-sh "nirius focus-or-spawn -a \"spt - spotatui\" ghostty -- --background-opacity=0.8 --font-size=18 --class=com.terminal.spotatui -e spotatui"; }

    // Mod+Space hotkey-overlay-title="Run an Application" {spawn-sh "vicinae toggle"; }
    Mod+Space hotkey-overlay-title="Run an Application" {spawn "thundersearch"; }
    Mod+Ctrl+V hotkey-overlay-title="Show clipboard history" { spawn-sh "vicinae vicinae://extensions/vicinae/clipboard/history"; }
    Super+Alt+L hotkey-overlay-title="Lock the Screen: swaylock" { spawn "swaylock"; }

    Mod+F4 hotkey-overlay-title="Toggle System dark/light theme" { spawn-sh "~/.config/niri/scripts/toggle-theme-global.sh"; }

    XF86AudioRaiseVolume allow-when-locked=true { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "0.1+"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "0.1-"; }
    XF86AudioMute        allow-when-locked=true { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SINK@" "toggle"; }
    XF86AudioMicMute     allow-when-locked=true { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SOURCE@" "toggle"; }

    XF86AudioNext         allow-when-locked=true { spawn-sh "playerctl next"; }
    XF86AudioPause        allow-when-locked=true { spawn-sh "playerctl play-pause"; }
    XF86AudioPlay         allow-when-locked=true { spawn-sh "playerctl play-pause"; }
    XF86AudioPrev         allow-when-locked=true { spawn-sh "playerctl previous"; }

    XF86MonBrightnessUp   allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "+10%"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "10%-"; }


    Mod+Q repeat=false { close-window; }

    Mod+Left  { focus-column-left; }
    Mod+Down  { focus-window-or-workspace-down; }
    Mod+Up    { focus-window-or-workspace-up; }
    Mod+Right { focus-column-right; }
    Mod+H     { focus-column-left; }
    Mod+J     { focus-window-or-workspace-down; }
    Mod+K     { focus-window-or-workspace-up; }
    Mod+L     { focus-column-right; }

    Mod+Ctrl+Left  { move-column-left-or-to-monitor-left; }
    Mod+Ctrl+Down  { move-window-down-or-to-workspace-down; }
    Mod+Ctrl+Up    { move-window-up-or-to-workspace-up; }
    Mod+Ctrl+Right { move-column-right-or-to-monitor-right; }
    Mod+Ctrl+H     { move-column-left-or-to-monitor-left; }
    Mod+Ctrl+J     { move-window-down-or-to-workspace-down; }
    Mod+Ctrl+K     { move-window-up-or-to-workspace-up; }
    Mod+Ctrl+L     { move-column-right-or-to-monitor-right; }

    Mod+Home { focus-column-first; }
    Mod+End  { focus-column-last; }
    Mod+Ctrl+Home { move-column-to-first; }
    Mod+Ctrl+End  { move-column-to-last; }

    Mod+Shift+Left  { focus-monitor-left; }
    Mod+Shift+Down  { focus-monitor-down; }
    Mod+Shift+Up    { focus-monitor-up; }
    Mod+Shift+Right { focus-monitor-right; }
    Mod+Shift+H     { focus-monitor-left; }
    Mod+Shift+J     { focus-monitor-down; }
    Mod+Shift+K     { focus-monitor-up; }
    Mod+Shift+L     { focus-monitor-right; }

    Mod+Shift+Ctrl+Left  { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+Down  { move-column-to-monitor-down; }
    Mod+Shift+Ctrl+Up    { move-column-to-monitor-up; }
    Mod+Shift+Ctrl+Right { move-column-to-monitor-right; }
    Mod+Shift+Ctrl+H     { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+J     { move-column-to-monitor-down; }
    Mod+Shift+Ctrl+K     { move-column-to-monitor-up; }
    Mod+Shift+Ctrl+L     { move-column-to-monitor-right; }

    Mod+Page_Down      { focus-workspace-down; }
    Mod+Page_Up        { focus-workspace-up; }
    Mod+U              { focus-workspace-down; }
    Mod+I              { focus-workspace-up; }
    Mod+Ctrl+Page_Down { move-column-to-workspace-down; }
    Mod+Ctrl+Page_Up   { move-column-to-workspace-up; }
    Mod+Ctrl+U         { move-column-to-workspace-down; }
    Mod+Ctrl+I         { move-column-to-workspace-up; }

    Mod+Shift+Page_Down { move-workspace-down; }
    Mod+Shift+Page_Up   { move-workspace-up; }
    Mod+Shift+U         { move-workspace-down; }
    Mod+Shift+I         { move-workspace-up; }

    Mod+WheelScrollDown      cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp        cooldown-ms=150 { focus-workspace-up; }
    Mod+Ctrl+WheelScrollDown cooldown-ms=150 { move-column-to-workspace-down; }
    Mod+Ctrl+WheelScrollUp   cooldown-ms=150 { move-column-to-workspace-up; }

    Mod+WheelScrollRight      { focus-column-right; }
    Mod+WheelScrollLeft       { focus-column-left; }
    Mod+Ctrl+WheelScrollRight { move-column-right; }
    Mod+Ctrl+WheelScrollLeft  { move-column-left; }

    Mod+Shift+WheelScrollDown      { focus-column-right; }
    Mod+Shift+WheelScrollUp        { focus-column-left; }
    Mod+Ctrl+Shift+WheelScrollDown { move-column-right; }
    Mod+Ctrl+Shift+WheelScrollUp   { move-column-left; }

    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }
    Mod+Ctrl+1 { move-column-to-workspace 1; }
    Mod+Ctrl+2 { move-column-to-workspace 2; }
    Mod+Ctrl+3 { move-column-to-workspace 3; }
    Mod+Ctrl+4 { move-column-to-workspace 4; }
    Mod+Ctrl+5 { move-column-to-workspace 5; }
    Mod+Ctrl+6 { move-column-to-workspace 6; }
    Mod+Ctrl+7 { move-column-to-workspace 7; }
    Mod+Ctrl+8 { move-column-to-workspace 8; }
    Mod+Ctrl+9 { move-column-to-workspace 9; }

    Mod+BracketLeft  { consume-or-expel-window-left; }
    Mod+BracketRight { consume-or-expel-window-right; }

    Mod+Comma  { consume-window-into-column; }
    Mod+Period { expel-window-from-column; }

    Mod+R { switch-preset-column-width; }
    Mod+Shift+R { switch-preset-column-width-back; }
    Mod+F { maximize-column; }
    F11 { fullscreen-window; }
    Mod+Shift+F { toggle-windowed-fullscreen; }
    Mod+Ctrl+F { expand-column-to-available-width; }
    Mod+C { center-column; }
    Mod+Ctrl+C { center-visible-columns; }

    Mod+Minus { set-column-width "-5%"; }
    Mod+Equal { set-column-width "+5%"; }

    Mod+Shift+Minus { set-window-height "-5%"; }
    Mod+Shift+Equal { set-window-height "+5%"; }

    Mod+T { toggle-column-tabbed-display; }
    Mod+V       { toggle-window-floating; }
    Mod+Shift+V { switch-focus-between-floating-and-tiling; }

    Print { screenshot; }
    Ctrl+Print { screenshot-screen show-pointer=false; }
    Alt+Print { screenshot-window; }

    Mod+Tab repeat=false { toggle-overview; }

    Mod+Shift+Q { spawn "systemctl" "suspend"; }
    // Ctrl+Alt+Delete { spawn "walker" "-nm" "menus:power"; }

    Mod+D hotkey-overlay-title="Change Speaker" { spawn "~/.config/niri/scripts/sinks-rotation.sh";}

    Mod+P hotkey-overlay-title="Toggle Notebook Screen On/Off" { spawn-sh "~/.config/niri/scripts/output_toggle.sh notebook";}
    Mod+Shift+P hotkey-overlay-title="Toggle External Screen On/Off" { spawn-sh "~/.config/niri/scripts/output_toggle.sh external";}
    Mod+Ctrl+P hotkey-overlay-title="Toggle All Screens On/Off" { power-off-monitors; }
}

overview {
    zoom 0.3
    workspace-shadow { 
        off
    }
}

recent-windows {
    // off
    debounce-ms 750

    open-delay-ms 150

    highlight {
        active-color "#ffffff40"
        urgent-color "#ff9999ff"
        padding 30
        corner-radius 20
    }

    previews {
        max-height 600
        max-scale 1
    }

    binds {
        Alt+Tab         { next-window; }
        Alt+Shift+Tab   { previous-window; }
        Alt+grave       { next-window     filter="app-id"; }
        Alt+Shift+grave { previous-window filter="app-id"; }

        Mod+Tab         { next-window; }
        Mod+Shift+Tab   { previous-window; }
        Mod+grave       { next-window     filter="app-id"; }
        Mod+Shift+grave { previous-window filter="app-id"; }
    }
}

hotkey-overlay {
    skip-at-startup
}

environment {
    EGL_PLATFORM "wayland"
    QT_QPA_PLATFORM "wayland"
    MOZ_ENABLE_WAYLAND "1"
    ELECTRON_OZONE_PLATFORM_HINT "auto"
    GTK_IM_MODULE "simple"

    GBM_BACKEND "nvidia-drm"
    __GLX_VENDOR_LIBRARY_NAME "nvidia"
    __GL_DXVK_USE_LAST_PIPELINE_CACHE "1"

    // __EGL_VENDOR_LIBRARY_FILENAMES "/usr/share/glvnd/egl_vendor.d/10_nvidia.json"
    VK_ICD_FILENAMES "/usr/share/vulkan/icd.d/nvidia_icd.json"
    NVIDIA_DRIVER_CAPABILITIES "all"
    EGL_VENDOR_LIBRARY_NAME "nvidia"
    GSK_RENDERER "ngl"

    // DRI_PRIME "1"
    // LIBGL_ALWAYS_INDIRECT "1" 
    // LIBGL_LIBRARIES_PATH "/usr/lib64/"

    LIBVA_DRIVER_NAME "nvidia"
    AQ_DRM_DEVICES "/dev/dri/card1:/dev/dri/card0" // It forces card1 (NVIDIA GPU) to be prioritized over card0 (Intel/AMD iGPU)
    AQ_FORCE_LINEAR_BLIT "0" // OPTIONAL
    // It is a 50/50 chance it'll work fine for you. Try with and without.
    // Some people reported that it fixes a lot of things, but in my case
    // it ran only worse. 
    NVD_BACKEND "direct" // Allows for VAAPI Hardware Acceleration

    SSH_AUTH_SOCK "/run/user/1000/gcr/ssh"
}

cursor {
    xcursor-theme "Bibata-Modern-Classic"
    // xcursor-theme "GoogleDot-Black"
    // xcursor-theme "oreo_black_cursors"
    // xcursor-theme "Future-cursors"
    xcursor-size 24
}

prefer-no-csd

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

debug {
    keep-laptop-panel-on-when-lid-is-closed
    // emulate-zero-presentation-time
    render-drm-device "/dev/dri/renderD129"
    // ignore-drm-device "/dev/dri/renderD128"
    // render-drm-device "/dev/dri/card0"
    // keep-max-bpc-unchanged
    // restrict-primary-scanout-to-matching-format
    // disable-transactions
}


spawn-sh-at-startup "systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE XDG_SESSION_DESKTOP"
spawn-sh-at-startup "dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE XDG_SESSION_DESKTOP"

spawn-sh-at-startup "wl-paste --watch cliphist store"
// spawn-sh-at-startup "swaybg -c 000000"
// spawn-sh-at-startup "swaybg -m fill -i ~/.config/wallpapers/orion_nebula_nasa_heic0601a.jpg"
// spawn-sh-at-startup "swaybg -m fill -i ~/.config/wallpapers/4K-OLED-Backgrounds-for-Desktop.jpg"
// spawn-sh-at-startup "swaybg -m fill -i ~/.config/wallpapers/Monster Abstract Wallpaper 4k Pc Desktop 5300a.jpg"
// spawn-sh-at-startup "swaybg -m fill -i ~/.config/wallpapers/art002e015228orig.webp"
spawn-sh-at-startup "way-edges -c ~/.config/way-edges/config.kdl"
spawn-sh-at-startup "nm-applet"
spawn-sh-at-startup "syncthing serve"
spawn-sh-at-startup "QT_SCALE_FACTOR=1.5 vicinae server"
spawn-sh-at-startup "rudo"
spawn-sh-at-startup "ghostty --gtk-single-instance=true --quit-after-last-window-closed=false --initial-window=false"
spawn-sh-at-startup "niriusd"
spawn-sh-at-startup "~/.config/niri/scripts/output_toggle.sh notebook"

// spawn-sh-at-startup "systemctl --user start stasis"
// spawn-sh-at-startup "kmonad ~/.config/niri/kmonad.kbd"
// spawn-sh-at-startup "qs -c noctalia-shell"
spawn-sh-at-startup "swayidle timeout 601 'niri msg action power-off-monitors' timeout 600 'systemctl suspend'"

// Niri Session

// spawn-sh-at-startup "QT_QPA_PLATFORM=xcb sioyek"
spawn-sh-at-startup "prime-run firefox"
spawn-sh-at-startup "$HOME/.config/niri/scripts/toggle-theme-global.sh && $HOME/.config/niri/scripts/toggle-theme-global.sh"
// spawn-sh-at-startup "prime-run obsidian"


spawn-at-startup "systemctl" "--user" "import-environment" "SSH_AUTH_SOCK"
spawn-at-startup "valent" "--gapplication-service"

// include "./noctalia.kdl"
// include "sioyek.kdl"
