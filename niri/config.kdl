input {
    keyboard {
        xkb {
            layout "br"
            options "caps:escape_shifted_capslock"
        }
        numlock
    }
    touchpad {
        // off
        tap
        // dwt
        // dwtp
        // drag false
        // drag-lock
        natural-scroll
        // accel-speed 0.2
        // accel-profile "flat"
        // scroll-method "two-finger"
        // disabled-on-external-mouse
    }
    mouse {
        // off
        // natural-scroll
        // accel-speed 0.2
        // accel-profile "flat"
        // scroll-method "no-scroll"
    }
    trackpoint {
        // off
        // natural-scroll
        // accel-speed 0.2
        // accel-profile "flat"
        // scroll-method "on-button-down"
        // scroll-button 273
        // middle-emulation
    }

    workspace-auto-back-and-forth
    // warp-mouse-to-focus
    focus-follows-mouse max-scroll-amount="15%"
}

gestures {
    hot-corners {
        // off
    }
}

output "eDP-1" {
    scale 1
    position x=0 y=0
}

output "DP-1" {
    scale 1
    position x=1920 y=0
}

layout {
    gaps 0

    background-color "transparent"
    center-focused-column "never" // always | on-overflow
    always-center-single-column

    preset-column-widths {
        proportion 0.2
        proportion 0.4
        proportion 0.5
        proportion 0.6
        proportion 0.8
    }

    default-column-width { proportion 0.5; }

    focus-ring {
        off
        width 1
        active-color "#ffffff33"
    }

    border {
        // off
        width 0
        active-color "#222"
        inactive-color "#222"
        // inactive-gradient from="#000" to="#555" angle=180
    }

    shadow {
        // on
        softness 20
        spread 5
        offset x=0 y=0
    }

    tab-indicator {
        width 2
        gap -5
        gaps-between-tabs 5
        corner-radius 10
        active-color "#fff"
        inactive-color "#ffffff55"
    }

    insert-hint {
        color "#ffffff22"
    }

    struts {
        // left 15
        // right 15
        // top -1
        // bottom -1
    }
}

