startup_commands toggle_custom_color;fit_to_page_width_smart

ui_font				SF Pro Text
status_font			SF Pro Text
font_size    			16
status_bar_font_size    	16
dark_mode_background_color	0.3  0.3  0.3
dark_mode_contrast		0.9
text_highlight_color       	#a59fed

